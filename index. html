<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Traductor Nica Milton</title>
    <!-- Cargar React y ReactDOM de forma estable -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <!-- Cargar Babel Standalone estable -->
    <script src="https://unpkg.com/@babel/standalone@7.23.10/babel.min.js"></script>
    <!-- Tailwind CSS para diseño premium -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Iconos Phosphor para detalles de interfaz -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        body {
            font-family: 'Inter', sans-serif;
        }
        .fade-in {
            animation: fadeIn 0.3s ease-in-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-slate-900 via-indigo-950 to-blue-950 min-h-screen flex items-center justify-center p-3 sm:p-6">

    <div id="root" class="w-full max-w-2xl"></div>

    <script type="text/babel">
        // Extraemos Hooks directamente desde el objeto global de React para evitar usar "import"
        const { useState, useEffect } = React;

        const App = () => {
            const [inputText, setInputText] = useState('');
            const [translationMode, setTranslationMode] = useState('nicaToStandard'); 
            const [translation, setTranslation] = useState(null);
            const [isLoading, setIsLoading] = useState(false);
            const [error, setError] = useState(null);
            
            // Gestión de la API Key en LocalStorage
            const [apiKey, setApiKey] = useState('');
            const [showSettings, setShowSettings] = useState(false);
            const [tempKey, setTempKey] = useState('');

            // Cargar API Key guardada al iniciar
            useEffect(() => {
                const savedKey = localStorage.getItem('nica_translator_apikey');
                if (savedKey) {
                    setApiKey(savedKey);
                    setTempKey(savedKey);
                }
            }, []);

            // Guardar API Key
            const saveApiKey = () => {
                localStorage.setItem('nica_translator_apikey', tempKey);
                setApiKey(tempKey);
                setShowSettings(false);
            };

            // Borrar API Key
            const clearApiKey = () => {
                localStorage.removeItem('nica_translator_apikey');
                setApiKey('');
                setTempKey('');
            };

            // Diccionario local rápido (para cuando no hay internet o API Key conectada)
            const localDictionary = {
                "chele": "Persona de tez clara o rubia.",
                "tuani": "Algo excelente, genial, bonito o de buena calidad.",
                "deacachimba": "Espectacular, sumamente bueno o excelente.",
                "palmado": "Sin dinero, quebrado financieramente.",
                "ideay": "Expresión de sorpresa, reclamo o saludo ('¿Qué pasó?').",
                "arrecho": "Enojado, furioso o con mal carácter.",
                "batuquear": "Mover fuertemente un líquido o agitar cosas.",
                "chigüín": "Niño pequeño, muchacho.",
                "chunche": "Cosa, objeto cuyo nombre no se recuerda.",
                "pofi": "Amigo íntimo, compañero de confianza.",
                "maje": "Persona, amigo (o tonto, según el contexto de uso)."
            };

            const translateText = async () => {
                if (!inputText.trim()) {
                    setError('Por favor, ingresa algún texto para traducir.');
                    setTranslation(null);
                    return;
                }

                setIsLoading(true);
                setError(null);
                setTranslation(null);

                // Si no hay API Key, intentamos hacer una búsqueda rápida local
                if (!apiKey) {
                    const word = inputText.toLowerCase().trim();
                    if (localDictionary[word]) {
                        setTranslation({
                            translatedText: localDictionary[word],
                            terms: [{
                                term: word,
                                explanation: "Definición cargada desde el catálogo local rápido de la aplicación."
                            }]
                        });
                        setIsLoading(false);
                        return;
                    }
                    
                    // Si no está en el catálogo local y no hay API Key, mostramos un error amigable
                    setError('Falta conectar tu API Key gratuita de Gemini para traducciones automáticas completas. Ve al botón de configuración ⚙️ arriba para guardarla.');
                    setIsLoading(false);
                    return;
                }

                // Configuración de prompts
                let prompt = '';
                if (translationMode === 'nicaToStandard') {
                    prompt = `Traduce el siguiente texto en Español Nicaragüense (que contiene jergas, modismos, regionalismos o lenguaje informal de Nicaragua) a un español estándar neutro y comprensible.
                    Identifica y explica detalladamente cada término o frase nicaragüense utilizada.
                    
                    Texto Original: "${inputText}"
                    
                    Devuelve la respuesta estrictamente como un objeto JSON con esta estructura:
                    {
                        "translatedText": "Texto traducido al español estándar neutro",
                        "terms": [
                            {
                                "term": "Palabra o frase nica identificada",
                                "explanation": "Explicación clara de su significado y contexto en el Español Nicaragüense"
                            }
                        ]
                    }`;
                } else if (translationMode === 'nicaToEnglish') {
                    prompt = `Translate the following Nicaraguan Spanish text (with local slang, idioms, or regionalisms) into natural, equivalent English.
                    Provide both a natural translation and, where possible, equivalent English slang/idioms. Also, identify and explain the Nicaraguan terms in English.
                    
                    Original Text: "${inputText}"
                    
                    Return the response strictly as a JSON object with this structure:
                    {
                        "translatedText": "Natural English translation",
                        "terms": [
                            {
                                "term": "Nicaraguan word or phrase identified",
                                "explanation": "Clear explanation of its meaning and equivalent in English"
                            }
                        ]
                    }`;
                } else if (translationMode === 'standardToNica') {
                    prompt = `Traduce el siguiente texto en español estándar o formal a un Español Nicaragüense coloquial y natural, incorporando adecuadamente jergas, modismos y regionalismos de Nicaragua (¡Nicanízalo de forma auténtica!).
                    Explica las principales expresiones o cambios que agregaste para que el usuario entienda cómo se adaptó.
                    
                    Texto Original: "${inputText}"
                    
                    Devuelve la respuesta estrictamente como un objeto JSON con esta estructura:
                    {
                        "translatedText": "Texto adaptado al Español Nicaragüense coloquial de forma natural",
                        "terms": [
                            {
                                "term": "Jerga o modismo nica introducido",
                                "explanation": "Significado de la expresión y por qué se usó en este contexto"
                            }
                        ]
                    }`;
                } else if (translationMode === 'usSlangToSpanish') {
                    prompt = `Traduce el siguiente texto en inglés de EE.UU. (que contiene jergas americanas (slang), modismos (idioms), lenguaje informal o regionalismos estadounidenses) a su recipiente más natural en español.
                    Puedes dar el equivalente tanto en español estándar como en Español Nicaragüense si existe un modismo similar.
                    Identifica y explica cada término informal en inglés estadounidense.
                    
                    Texto Original: "${inputText}"
                    
                    Devuelve la respuesta estrictamente como un objeto JSON con esta estructura:
                    {
                        "translatedText": "Traducción natural al español (puedes incluir la opción estándar y la opción nica equivalente si aplica)",
                        "terms": [
                            {
                                "term": "Slang, idiom o regionalismo estadounidense identificado",
                                "explanation": "Explicación detallada de lo que significa en EE.UU. y sus equivalentes coloquiales en español"
                            }
                        ]
                    }`;
                } else if (translationMode === 'englishToUsSlang') {
                    prompt = `Transform the following standard English text into informal American English, rich with US slang, idioms, and natural colloquial regionalisms.
                    Explain the slang or changes introduced so the user can learn how to speak informally in the US.
                    
                    Original Text: "${inputText}"
                    
                    Return the response strictly as a JSON object with this structure:
                    {
                        "translatedText": "American informal/slang translation",
                        "terms": [
                            {
                                "term": "American slang or idiom introduced",
                                "explanation": "What it means and why it was chosen for this context"
                            }
                        ]
                    }`;
                }

                const payload = {
                    contents: [{ parts: [{ text: prompt }] }],
                    generationConfig: {
                        responseMimeType: "application/json",
                        responseSchema: {
                            type: "OBJECT",
                            properties: {
                                "translatedText": { "type": "STRING" },
                                "terms": {
                                    "type": "ARRAY",
                                    "items": {
                                        "type": "OBJECT",
                                        "properties": {
                                            "term": { "type": "STRING" },
                                            "explanation": { "type": "STRING" }
                                        },
                                        "required": ["term", "explanation"]
                                    }
                                }
                            },
                            "required": ["translatedText", "terms"]
                        }
                    }
                };

                const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;

                try {
                    const response = await fetch(apiUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        throw new Error(`Servidor respondió con código ${response.status}. Verifica que tu API Key sea correcta.`);
                    }

                    const result = await response.json();

                    if (result.candidates && result.candidates[0]?.content?.parts[0]?.text) {
                        const jsonText = result.candidates[0].content.parts[0].text;
                        const parsedJson = JSON.parse(jsonText);
                        setTranslation(parsedJson);
                    } else {
                        setError('No se pudo procesar la traducción en este momento.');
                    }
                } catch (err) {
                    setError(err.message || 'Error de conexión. Revisa tu internet o clave de API.');
                } finally {
                    setIsLoading(false);
                }
            };

            const getPlaceholder = () => {
                switch (translationMode) {
                    case 'standardToNica':
                        return 'Escribe algo formal (ej. "Hola amigo, estoy sumamente agotado y no tengo dinero")...';
                    case 'usSlangToSpanish':
                        return 'Escribe jerga de EE.UU. (ej. "What\'s up dude, I\'m totally broke")...';
                    case 'englishToUsSlang':
                        return 'Write standard English (e.g. "Hello my friend, I am very excited")...';
                    default:
                        return 'Escribe en Español Nicaragüense (ej. "Ideay chele, ando bien palmado")...';
                }
            };

            const getLabel = () => {
                switch (translationMode) {
                    case 'nicaToStandard': return 'Nica ➜ Español Estándar';
                    case 'nicaToEnglish': return 'Nica ➜ Inglés Equivalente';
                    case 'standardToNica': return 'Español Estándar ➜ Nica';
                    case 'usSlangToSpanish': return 'Slang EE.UU. ➜ Español (Nica/Estándar)';
                    case 'englishToUsSlang': return 'English Estándar ➜ Slang EE.UU.';
                    default: return 'Traductor';
                }
            };

            return (
                <div className="bg-slate-900/90 border border-slate-800 p-5 md:p-8 rounded-2xl shadow-2xl w-full text-white backdrop-blur-md transition-all duration-300">
                    
                    <div className="flex justify-between items-start mb-6">
                        <div className="text-left">
                            <h1 className="text-2xl sm:text-4xl font-extrabold tracking-tight leading-tight">
                                <span className="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">
                                    Traductor Nica
                                </span>{" "}
                                <span className="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-300">
                                    Milton
                                </span>
                            </h1>
                            <p className="text-xs sm:text-sm text-slate-400 font-semibold uppercase tracking-wider mt-1">
                                El Puente de los Modismos Coloquiales
                            </p>
                        </div>
                        
                        {/* Botón de Ajustes de API Key */}
                        <button 
                            onClick={() => setShowSettings(!showSettings)}
                            className="p-2 rounded-xl bg-slate-800 text-slate-300 hover:text-white hover:bg-slate-700 transition"
                            title="Configurar API Key de Gemini"
                        >
                            <i className="ph-bold ph-gear text-xl"></i>
                        </button>
                    </div>

                    {showSettings && (
                        <div className="mb-6 p-4 bg-slate-800/80 border border-slate-700 rounded-xl fade-in text-sm text-slate-300">
                            <h3 className="font-bold text-white mb-2 flex items-center gap-2">
                                <i className="ph-bold ph-key"></i> Clave de API de Gemini (Google)
                            </h3>
                            <p className="text-xs text-slate-400 mb-3">
                                Ingresa tu API Key para habilitar la traducción inteligente. Se guarda de forma segura en tu celular.
                            </p>
                            <div className="flex gap-2">
                                <input 
                                    type="password"
                                    value={tempKey}
                                    onChange={(e) => setTempKey(e.target.value)}
                                    placeholder="AIzaSy..."
                                    className="flex-grow bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-white text-xs focus:ring-2 focus:ring-emerald-500 focus:outline-none"
                                />
                                <button 
                                    onClick={saveApiKey}
                                    className="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 rounded-lg text-white font-bold text-xs transition"
                                >
                                    Guardar
                                </button>
                                {apiKey && (
                                    <button 
                                        onClick={clearApiKey}
                                        className="px-3 py-2 bg-rose-900/50 hover:bg-rose-900 text-rose-300 rounded-lg text-xs font-semibold transition"
                                    >
                                        Limpiar
                                    </button>
                                )}
                            </div>
                        </div>
                    )}

                    {/* Estado de conexión de API Key */}
                    {!apiKey && !showSettings && (
                        <div className="mb-6 p-3 bg-amber-950/30 border border-amber-900/60 rounded-xl flex items-center justify-between text-xs text-amber-300/90 animate-pulse">
                            <span className="flex items-center gap-1.5">
                                <i className="ph-bold ph-warning-circle text-sm"></i>
                                Traductor trabajando en modo local básico.
                            </span>
                            <button 
                                onClick={() => setShowSettings(true)}
                                className="underline font-bold hover:text-amber-200"
                            >
                                Conectar API Key
                            </button>
                        </div>
                    )}

                    <div className="space-y-4 mb-5">
                        <div className="bg-slate-950/60 p-3 rounded-xl border border-slate-800">
                            <span className="block text-[10px] font-extrabold text-blue-400 uppercase tracking-widest mb-2">
                                Modos Nicaragüenses & Estándar
                            </span>
                            <div className="grid grid-cols-1 sm:grid-cols-3 gap-1.5">
                                <button
                                    onClick={() => { setTranslationMode('nicaToStandard'); setTranslation(null); }}
                                    className={`py-2 px-3 rounded-lg font-bold text-xs transition-all ${
                                        translationMode === 'nicaToStandard'
                                            ? 'bg-blue-600 text-white shadow-md'
                                            : 'bg-slate-900 text-slate-400 hover:bg-slate-850 hover:text-slate-200 border border-slate-800'
                                    }`}
                                >
                                    Nica ➜ Estándar
                                </button>
                                <button
                                    onClick={() => { setTranslationMode('nicaToEnglish'); setTranslation(null); }}
                                    className={`py-2 px-3 rounded-lg font-bold text-xs transition-all ${
                                        translationMode === 'nicaToEnglish'
                                            ? 'bg-blue-600 text-white shadow-md'
                                            : 'bg-slate-900 text-slate-400 hover:bg-slate-850 hover:text-slate-200 border border-slate-800'
                                    }`}
                                >
                                    Nica ➜ Inglés
                                </button>
                                <button
                                    onClick={() => { setTranslationMode('standardToNica'); setTranslation(null); }}
                                    className={`py-2 px-3 rounded-lg font-bold text-xs transition-all ${
                                        translationMode === 'standardToNica'
                                            ? 'bg-emerald-600 text-white shadow-md'
                                            : 'bg-slate-900 text-slate-400 hover:bg-slate-850 hover:text-slate-200 border border-slate-800'
                                    }`}
                                >
                                    Estándar ➜ Nica
                                </button>
                            </div>
                        </div>

                        <div className="bg-slate-950/60 p-3 rounded-xl border border-slate-800">
                            <span className="block text-[10px] font-extrabold text-purple-400 uppercase tracking-widest mb-2">
                                Modos Slang EE.UU. (Inglés)
                            </span>
                            <div className="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
                                <button
                                    onClick={() => { setTranslationMode('usSlangToSpanish'); setTranslation(null); }}
                                    className={`py-2 px-3 rounded-lg font-bold text-xs transition-all ${
                                        translationMode === 'usSlangToSpanish'
                                            ? 'bg-purple-600 text-white shadow-md'
                                            : 'bg-slate-900 text-slate-400 hover:bg-slate-850 hover:text-slate-200 border border-slate-800'
                                    }`}
                                >
                                    🇺🇸 Slang EE.UU. ➜ Español (Nica/Estándar)
                                </button>
                                <button
                                    onClick={() => { setTranslationMode('englishToUsSlang'); setTranslation(null); }}
                                    className={`py-2 px-3 rounded-lg font-bold text-xs transition-all ${
                                        translationMode === 'englishToUsSlang'
                                            ? 'bg-purple-600 text-white shadow-md'
                                            : 'bg-slate-900 text-slate-400 hover:bg-slate-850 hover:text-slate-200 border border-slate-800'
                                    }`}
                                >
                                    English Estándar ➜ 🇺🇸 Slang EE.UU.
                                </button>
                            </div>
                        </div>
                    </div>

                    <div className="mb-4">
                        <textarea
                            className="w-full p-4 bg-slate-950 border-2 border-slate-800 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition-all duration-350 text-sm sm:text-base resize-none min-h-[110px] placeholder-slate-500 font-medium"
                            placeholder={getPlaceholder()}
                            value={inputText}
                            onChange={(e) => setInputText(e.target.value)}
                            rows="4"
                        ></textarea>
                    </div>

                    <button
                        onClick={translateText}
                        disabled={isLoading}
                        className={`w-full py-3.5 px-6 rounded-xl font-bold text-base shadow-lg transition-all duration-300 transform
                            ${
                                isLoading
                                    ? 'bg-slate-700 cursor-not-allowed animate-pulse text-slate-400'
                                    : 'bg-gradient-to-r from-blue-600 via-teal-600 to-emerald-600 hover:brightness-110 active:scale-[0.98] text-white'
                            } flex items-center justify-center gap-2`}
                    >
                        {isLoading ? (
                            <>
                                <svg className="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"></circle>
                                    <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                Traduciendo modismos...
                            </>
                        ) : (
                            <>
                                <i className="ph-bold ph-translate text-lg"></i>
                                {`Traducir en Modo: ${getLabel()}`}
                            </>
                        )}
                    </button>

                    {error && (
                        <div className="mt-5 p-4 bg-red-950/50 border border-red-900 text-red-300 rounded-xl text-xs sm:text-sm font-medium fade-in">
                            <p className="font-bold mb-1 flex items-center gap-1">
                                <i className="ph-bold ph-warning"></i> Error de Procesamiento:
                            </p>
                            <p>{error}</p>
                        </div>
                    )}

                    {translation && (
                        <div className="mt-6 pt-5 border-t border-slate-800 fade-in">
                            <h2 className="text-base sm:text-lg font-bold text-slate-300 mb-4 flex items-center gap-2">
                                <i className="ph-bold ph-sparkle text-emerald-400"></i> Traducción e Interpretación
                            </h2>

                            <div className={`p-4 rounded-xl mb-4 border shadow-sm ${
                                translationMode.includes('Nica') || translationMode === 'standardToNica'
                                    ? 'bg-emerald-950/20 border-emerald-900/55' 
                                    : 'bg-indigo-950/20 border-indigo-900/55'
                            }`}>
                                <h3 className={`text-[10px] font-extrabold mb-1.5 uppercase tracking-widest ${
                                    translationMode.includes('Nica') || translationMode === 'standardToNica'
                                        ? 'text-emerald-400' 
                                        : 'text-indigo-400'
                                }`}>
                                    Texto Traducido / Adaptado:
                                </h3>
                                <p className="text-slate-100 text-sm sm:text-base leading-relaxed font-semibold">
                                    {translation.translatedText}
                                </p>
                            </div>

                            {translation.terms && translation.terms.length > 0 && (
                                <div className="bg-slate-950/40 p-4 rounded-xl border border-slate-800">
                                    <h3 className="text-[10px] font-extrabold text-amber-400 mb-3 uppercase tracking-widest flex items-center gap-1">
                                        <i className="ph-bold ph-lightbulb"></i> Glosario de Modismos Clave:
                                    </h3>
                                    <div className="space-y-3">
                                        {translation.terms.map((termObj, index) => (
                                            <div key={index} className="border-b border-slate-800/60 pb-2.5 last:border-none last:pb-0">
                                                <p className="font-extrabold text-amber-300 text-xs sm:text-sm flex items-center gap-1">
                                                    ✨ {termObj.term}
                                                </p>
                                                <p className="text-slate-300 text-xs mt-1 leading-relaxed pl-5">
                                                    {termObj.explanation}
                                                </p>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            )}
                        </div>
                    )}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
